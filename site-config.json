{
  "version": 1,
  "domain": "music.lynxpardelle.com",
  "defaultPageId": "default",
  "routes": [
    {
      "path": "/",
      "pageId": "default",
      "label": "Home"
    }
  ],
  "site": {
    "theme": {
      "defaultMode": "dark",
      "palettes": {
        "light": {
          "bgColor": "#f2ece5",
          "textColor": "#1b1613",
          "titleColor": "#110d0b",
          "linkColor": "#8f6a34",
          "accentColor": "#8f6a34",
          "secondaryBgColor": "#e4d6ce",
          "secondaryTextColor": "#201815",
          "secondaryTitleColor": "#17110f",
          "secondaryLinkColor": "#aa3147",
          "secondaryAccentColor": "#7a2333",
          "successColor": "#198754",
          "onSuccessColor": "#052e1c",
          "errorColor": "#dc3545",
          "onErrorColor": "#3b0a10",
          "warningColor": "#f59e0b",
          "onWarningColor": "#3a2400",
          "infoColor": "#0d6efd",
          "onInfoColor": "#041b44"
        },
        "dark": {
          "bgColor": "#050505",
          "textColor": "#ded6cd",
          "titleColor": "#f5efe8",
          "linkColor": "#a9824a",
          "accentColor": "#a9824a",
          "secondaryBgColor": "#120d0f",
          "secondaryTextColor": "#e8ddd2",
          "secondaryTitleColor": "#fff6ed",
          "secondaryLinkColor": "#d14a5e",
          "secondaryAccentColor": "#822536",
          "successColor": "#32d583",
          "onSuccessColor": "#f3fff8",
          "errorColor": "#ff6b6b",
          "onErrorColor": "#fff5f5",
          "warningColor": "#f5b942",
          "onWarningColor": "#fff7e6",
          "infoColor": "#58a6ff",
          "onInfoColor": "#f5fbff"
        }
      },
      "ui": {
        "modalAccentColor": "secondaryAccentColor",
        "legalModalAccentColor": "secondaryAccentColor",
        "demoModalAccentColor": "accentColor"
      }
    },
    "appIdentity": {
      "identifier": "musiclynxpardellecom",
      "name": "LYNX PARDELLE",
      "version": "1.0.0",
      "description": "Music landing page for LYNX PARDELLE."
    },
    "seo": {
      "siteName": "LYNX PARDELLE",
      "title": "LYNX PARDELLE",
      "description": "Music landing page for LYNX PARDELLE.",
      "canonicalOrigin": "https://music.lynxpardelle.com",
      "defaultImage": "https://assets.zoolandingpage.com.mx/music.lynxpardelle.com/default/hero-images/lynx-pardelle-lince.png",
      "openGraph": {
        "type": "website",
        "site_name": "LYNX PARDELLE"
      },
      "twitter": {
        "card": "summary_large_image"
      },
      "keywords": [
        "Lynx Pardelle",
        "experimental electronic rock",
        "experimental music producer",
        "electronic rock artist",
        "Spotify",
        "Tidal"
      ],
      "robots": "index,follow,max-image-preview:large"
    },
    "i18n": {
      "defaultLanguage": "es",
      "supportedLanguages": [
        {
          "code": "es",
          "label": "ES"
        },
        {
          "code": "en",
          "label": "EN"
        },
        {
          "code": "fr",
          "label": "FR"
        },
        {
          "code": "de",
          "label": "DE"
        }
      ]
    }
  },
  "runtime": {
    "localStorage": {
      "theme": "music-landing-theme",
      "language": "music-landing-language",
      "userPreferences": "music-landing-preferences",
      "id": "music-landing-id",
      "sessionId": "music-landing-session-id",
      "allowAnalytics": "music-landing-allow-analytics",
      "analyticsConsentSnooze": "music-landing-allow-analytics-snooze",
      "pageViewCount": "music-landing-page-view-count"
    },
    "features": {
      "debugMode": false
    },
    "analytics": {
      "enabled": false,
      "consentUI": "none",
      "consentSnoozeSeconds": 30,
      "track": [
        "ip",
        "userAgent",
        "language",
        "platform",
        "vendor",
        "cookiesEnabled",
        "doNotTrack",
        "screenWidth",
        "screenHeight",
        "colorDepth",
        "timezone",
        "geolocationLatitude",
        "geolocationLongitude",
        "geolocationAccuracy",
        "cookies",
        "battery",
        "connection"
      ],
      "quickStats": {
        "pageView": {
          "event": "page_view",
          "path": "metrics.pageViews",
          "by": 1
        },
        "events": [
          {
            "name": "hero_primary_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "hero_secondary_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "services_cta_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "faq_cta_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "cta_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "final_cta_primary_click",
            "path": "metrics.ctaClicks",
            "by": 1
          },
          {
            "name": "final_cta_secondary_click",
            "path": "metrics.ctaClicks",
            "by": 1
          }
        ]
      }
    },
    "dataSources": [
      {
        "id": "lynx-itunes-songs",
        "proxySourceId": "itunesSongSearch",
        "target": "remote.music.releases",
        "statusTarget": "remoteStatus.music.releases",
        "enabled": true,
        "input": {
          "term": "lynx pardelle",
          "entity": "song",
          "limit": 6
        },
        "mapper": {
          "itemsPath": "results",
          "fields": {
            "title": "trackName",
            "href": "trackViewUrl",
            "description": {
              "path": "collectionName",
              "fallback": "Lynx Pardelle"
            },
            "artist": "artistName",
            "image": "artworkUrl100",
            "genre": "primaryGenreName"
          }
        },
        "refresh": {
          "mode": "interval",
          "intervalMs": 300000
        }
      },
      {
        "id": "lynx-tidal-albums",
        "proxySourceId": "tidalArtistAlbums",
        "target": "remote.music.tidalAlbums",
        "statusTarget": "remoteStatus.music.tidalAlbums",
        "enabled": false,
        "input": {
          "countryCode": "MX",
          "include": "albums"
        },
        "mapper": {
          "itemsPath": "included",
          "fields": {
            "id": "id",
            "title": "attributes.title",
            "href": {
              "path": "id",
              "prefix": "https://tidal.com/browse/album/"
            },
            "description": {
              "path": "attributes.releaseDate",
              "fallback": "TIDAL"
            },
            "image": {
              "path": "attributes.imageLinks.0.href",
              "fallback": ""
            },
            "provider": {
              "path": "type",
              "fallback": "TIDAL"
            }
          }
        },
        "refresh": {
          "mode": "interval",
          "intervalMs": 900000
        }
      }
    ]
  }
}
